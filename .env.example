# Copy to a local untracked .env file and fill with your own values.

SM_ROOT_GROUP_ID=oc_YOUR_ROOT_GROUP_CHAT_ID
SM_ROOT_USER_ID=ou_YOUR_OPEN_USER_ID
SM_WORKSPACE_ROOT=$HOME/SuperMatrixWorkspaces
SM_RUNTIME_ROOT=$HOME/SuperMatrixRuntime
SM_DB_PATH=$HOME/SuperMatrixRuntime/data/supermatrix.db
SM_BACKEND=claude
SM_LOG_LEVEL=info
LARK_APP_ID=cli_YOUR_APP_ID
LARK_APP_SECRET=YOUR_LOCAL_APP_SECRET
LARK_TENANT=feishu
SM_API_PORT=3501

# Optional local overrides.
SM_LARK_CLI_PATH=/absolute/path/to/supermatrix-public/supermatrix/node_modules/.bin/lark-cli
SM_API_BASE=http://localhost:3501
SM_SCHEDULER_BASE_URL=http://127.0.0.1:3500
SM_PREDICATE_PATCH_TOKEN=LOCAL_RANDOM_TOKEN
SM_REPO_ROOT=/absolute/path/to/supermatrix-public/supermatrix

# Optional localwatch supervisor.
SM_ENV_FILE=/absolute/path/to/supermatrix-public/.env
LOCALWATCH_HEARTBEAT_GROUP=
LOCALWATCH_SELFCHECK_TARGET=supermatrix-root
LOCALWATCH_SELFCHECK_FROM=supermatrix-root
SCHEDULER_CWD=/absolute/path/to/supermatrix-public/platform/scheduler
SCHEDULER_BIN=/absolute/path/to/supermatrix-public/platform/scheduler/dist/main.js
BUSINESS_SCREEN_CWD=
BUSINESS_SCREEN_PORT=4322
BUSINESS_SCREEN_HOST=0.0.0.0

# Optional backend defaults. Only set models your local account can use.
SM_CLAUDE_DEFAULT_MODEL=YOUR_CLAUDE_MODEL
SM_CODEX_DEFAULT_MODEL=YOUR_CODEX_MODEL
SM_KIMI_CLI_PATH=kimi

# Optional scheduler.
SCHEDULER_DB_PATH=$HOME/SuperMatrixRuntime/scheduler/scheduler.db
SCHEDULER_SUPERMATRIX_DB_PATH=$SM_DB_PATH
SCHEDULER_USER_DM_OPEN_ID=$SM_ROOT_USER_ID
SCHEDULER_SPAWN_API_URL=http://localhost:3501/api/spawn
SCHEDULER_NOTIFY_API_URL=http://localhost:3501/api/notify
SCHEDULER_BITABLE_BASE_TOKEN=
SCHEDULER_BITABLE_TABLE_ID=

# Optional autobitable webhook adapter.
AUTOBITABLE_PORT=3510
AUTOBITABLE_WEBHOOK_SECRET=REPLACE_WITH_LOCAL_SECRET
AUTOBITABLE_REGISTRY_PATH=platform/autobitable/registry/bitable-webhooks.json
AUTOBITABLE_RUN_STORE_PATH=$HOME/SuperMatrixRuntime/autobitable/webhook-runs.jsonl
AUTOBITABLE_LEDGER_BASE_TOKEN=
AUTOBITABLE_LEDGER_TABLE_ID=
AUTOBITABLE_PUBLIC_WEBHOOK_URL=https://YOUR_PUBLIC_HOST/feishu/bitable/webhook
AUTOBITABLE_LARK_CLI_PATH=$SM_LARK_CLI_PATH
# Optional watchdog.
WATCHDOG_DB_PATH=$HOME/SuperMatrixRuntime/watchdog/watchdog.db
WATCHDOG_NOTIFY_DISABLED=0
WATCHDOG_DISABLE_SYNC=0
WATCHDOG_LARK_CLI_PATH=$SM_LARK_CLI_PATH
WATCHDOG_BITABLE_BASE_TOKEN=
WATCHDOG_BITABLE_TABLE_ID=
WATCHDOG_DAILY_COMMIT_BASE_TOKEN=
WATCHDOG_DAILY_COMMIT_TABLE_ID=
WATCHDOG_SESSION_BASE_TOKEN=
WATCHDOG_SESSION_TABLE_ID=
WATCHDOG_DAILY_COMMIT_CODEX_BIN=codex
WATCHDOG_DAILY_COMMIT_CODEX_MODEL=YOUR_CODEX_MODEL
WATCHDOG_SAFE_RELOAD_PATH=$SM_REPO_ROOT/scripts/safe-reload.sh
WATCHDOG_SAFE_RELOAD_TASK_URL=
WATCHDOG_WEEKLY_RANK_CHAT_ID=
WATCHDOG_WEEKLY_TOKEN_CHAT_ID=
WATCHDOG_CLAUDE_BIN=claude
WATCHDOG_CODEX_BIN=codex
WATCHDOG_NPM_BIN=npm

# Optional skill-master Feishu targets and skill-specific keys.
SKILL_MASTER_FEISHU_BASE_TOKEN=
SKILL_MASTER_FEISHU_TABLE_ID=
SKILL_MASTER_CALL_COUNTS_TABLE_ID=
SKILL_MASTER_ISSUES_TABLE_ID=
SKILL_MASTER_LARK_CLI_PATH=$SM_LARK_CLI_PATH
SORFTIME_MCP_KEY=
LINGXING_APP_ID=
LINGXING_APP_SECRET=
LINGXING_RELAY_URL=
LINGXING_RELAY_TOKEN=
ZCLAW_API_KEY=

# Optional heartbeat. Requires Super Matrix API, readable SM_DB_PATH, a heartbeat session,
# and a controller model API key before patrols can run.
HEARTBEAT_WORKSPACE=$HOME/SuperMatrixWorkspaces/heartbeat
HEARTBEAT_STATE_DB=$HOME/SuperMatrixWorkspaces/heartbeat/data/heartbeat.sqlite
HEARTBEAT_SESSION=heartbeat
HEARTBEAT_CONTROLLER_PROVIDER=minimax
HEARTBEAT_CONTROLLER_MODEL=MiniMax-M2.7
HEARTBEAT_ESCALATION_MODEL=YOUR_ESCALATION_MODEL
HEARTBEAT_MINIMAX_API_KEY=
HEARTBEAT_MINIMAX_BASE_URL=https://api.minimaxi.com/v1
HEARTBEAT_LOG_FEISHU_BASE_TOKEN=
HEARTBEAT_LOG_FEISHU_TABLE_ID=

# Optional First Principle Feishu mirror targets.
FEISHU_WIKI_BASE_URL=https://YOUR_TENANT.feishu.cn/wiki
FP_SESSION_BASE_TOKEN=
FP_SESSION_TABLE_ID=
FP_PATROL_BASE_TOKEN=
FP_PATROL_TABLE_ID=
FP_CHANGELOG_TABLE_ID=
FP_HEARTBEAT_FIELD_ID=

# Optional Social King / Mythos Feishu mirror targets.
SOCIAL_KING_BASE_TOKEN=
SOCIAL_KING_TABLE_ID=
MYTHOS_FEISHU_BASE_TOKEN=
MYTHOS_SOURCES_TABLE_ID=
MYTHOS_QUERIES_TABLE_ID=
MYTHOS_PARENT_NODE_TOKEN=
MYTHOS_FEISHU_SPACE_ID=
