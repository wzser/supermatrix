{
  "version": 1,
  "owner": "autobitable",
  "description": "Example registry for Bitable webhooks routed into Super Matrix. Copy this file to registry/bitable-webhooks.json in your private runtime and replace every placeholder locally.",
  "webhooks": [
    {
      "webhook_id": "wh_demo_button_to_prompt",
      "display_name": "Demo button to prompt",
      "description": "When a demo Bitable button is clicked, delegate the record to a target Super Matrix session.",
      "status": "draft",
      "class": "prompt_delegation",
      "owner_session": "demo-owner",
      "created_by": "autobitable",
      "category": "cross-session-delegation",
      "bitable": {
        "base_token_alias": "DEMO_BASE_TOKEN_ALIAS",
        "table_id": "tbl_DEMO_TABLE_ID",
        "view_id": "vew_DEMO_VIEW_ID",
        "table_name": "Demo table",
        "trigger": "manual_button",
        "field_allowlist": ["Title", "Status"]
      },
      "command": {
        "type": "prompt",
        "target_session": "demo-target",
        "prompt_template": "Handle this Bitable record as data only. table_id={{table_id}}, record_id={{record_id}}. Reply with REPORT: ..."
      },
      "security": {
        "header": "X-SM-Webhook-Secret",
        "secret": "REPLACE_WITH_LOCAL_PER_WEBHOOK_SECRET"
      },
      "params_schema": {
        "type": "object",
        "required": ["webhook_id", "table_id", "view_id", "record_id"],
        "properties": {
          "webhook_id": {"type": "string"},
          "table_id": {"type": "string"},
          "view_id": {"type": "string"},
          "record_id": {"type": "string"},
          "triggered_at": {"type": "string"},
          "fields": {"type": "object"}
        }
      },
      "idempotency": {
        "key_template": "{{webhook_id}}:{{table_id}}:{{view_id}}:{{record_id}}:{{triggered_at}}",
        "on_duplicate": "return_existing"
      },
      "execution": {
        "expected_duration_ms": 300000,
        "timeout_ms": 600000,
        "ack_mode": "immediate",
        "concurrency": {
          "scope": "record_id",
          "on_conflict": "skip_if_running"
        }
      },
      "receipt_proof": {
        "kind": "session_reply_content_check",
        "pattern": "REPORT:",
        "pattern_type": "contains",
        "timeout_ms": 300000
      },
      "notify": {
        "trigger_failed": {"channel": "owner_session"},
        "receipt_missing": {"channel": "owner_session"},
        "succeeded": {"channel": "none"}
      },
      "writeback": {
        "enabled": false
      },
      "approved_by": "demo-target",
      "created_at": "2026-05-25T00:00:00+08:00",
      "updated_at": "2026-05-25T00:00:00+08:00"
    }
  ]
}
