#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from heartbeat_patrol.config import load_config
from heartbeat_patrol.sm_reader import SuperMatrixReader
from heartbeat_patrol.state import HeartbeatState


def main() -> int:
    parser = argparse.ArgumentParser(description="Enqueue an idempotent heartbeat todo for a session.")
    parser.add_argument("--session", required=True)
    parser.add_argument("--key", required=True)
    parser.add_argument("--message", required=True)
    parser.add_argument("--source", default="heartbeat-cli")
    parser.add_argument("--source-session", default="")
    parser.add_argument("--source-ref", default="")
    parser.add_argument("--todo-type", default="general")
    parser.add_argument("--batch-key", default="")
    parser.add_argument("--batch-mode", choices=["auto", "single"], default="auto")
    parser.add_argument("--expected-count", type=int)
    parser.add_argument("--settle-after-seconds", type=int, default=600)
    parser.add_argument("--max-wait-seconds", type=int, default=1800)
    args = parser.parse_args()

    try:
        cfg = load_config()
        session = SuperMatrixReader(cfg.sm_db_path).get_session_by_name(args.session)
        if session is None:
            print(json.dumps({"ok": False, "error": f"session not found: {args.session}"}, ensure_ascii=False))
            return 2
        result = HeartbeatState(cfg.state_db_path).enqueue_todo(
            target_session=session["name"],
            logical_key=args.key,
            message=args.message,
            source=args.source,
            source_session=args.source_session,
            source_ref=args.source_ref,
            todo_type=args.todo_type,
            target_heartbeat_enabled=session.get("heartbeat_enabled") == 1,
            batch_key=args.batch_key,
            batch_mode=args.batch_mode,
            expected_count=args.expected_count,
            settle_after_seconds=args.settle_after_seconds,
            max_wait_seconds=args.max_wait_seconds,
        )
    except Exception as exc:
        print(json.dumps({"ok": False, "error": str(exc)}, ensure_ascii=False))
        return 1

    if result.get("status") == "target_not_heartbeat_enabled":
        print(json.dumps({"ok": False, **result}, ensure_ascii=False))
        return 3

    print(json.dumps({"ok": True, **result}, ensure_ascii=False, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
