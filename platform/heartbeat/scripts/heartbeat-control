#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from heartbeat_patrol.config import load_config
from heartbeat_patrol.state import HeartbeatState


def main() -> int:
    parser = argparse.ArgumentParser(description="Record heartbeat pause/resume state in the local heartbeat DB.")
    sub = parser.add_subparsers(dest="action", required=True)

    pause = sub.add_parser("pause")
    pause.add_argument("--session", required=True)
    pause.add_argument("--minutes", type=int)
    pause.add_argument("--permanent", action="store_true")
    pause.add_argument("--reason", default="")
    pause.add_argument("--source", default="heartbeat_command")

    resume = sub.add_parser("resume")
    resume.add_argument("--session", required=True)
    resume.add_argument("--reason", default="")
    resume.add_argument("--source", default="heartbeat_command")

    status = sub.add_parser("status")
    status.add_argument("--session", required=True)

    args = parser.parse_args()
    state = HeartbeatState(load_config().state_db_path)

    if args.action == "pause":
        result = state.pause_session(
            session_name=args.session,
            minutes=args.minutes,
            permanent=args.permanent,
            reason=args.reason,
            source=args.source,
        )
    elif args.action == "resume":
        result = state.resume_session(session_name=args.session, reason=args.reason, source=args.source)
    else:
        result = state.active_pause_for_session(args.session) or {"session_name": args.session, "status": "active"}

    print(json.dumps({"ok": True, **result}, ensure_ascii=False, sort_keys=True))
    return 0


if __name__ == "__main__":
    sys.exit(main())
