#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from heartbeat_patrol.config import load_config
from heartbeat_patrol.event_sync import sync_events_to_feishu
from heartbeat_patrol.runner import build_default_runner
from heartbeat_patrol.state import HeartbeatState


def main() -> int:
    cfg = load_config()
    runner = build_default_runner(cfg)
    result = runner.run_once()
    base_token = os.environ.get("HEARTBEAT_LOG_FEISHU_BASE_TOKEN", "").strip()
    table_id = os.environ.get("HEARTBEAT_LOG_FEISHU_TABLE_ID", "").strip()
    if base_token and table_id:
        try:
            result["feishu_sync"] = sync_events_to_feishu(
                state=HeartbeatState(cfg.state_db_path),
                base_token=base_token,
                table_id=table_id,
                lark_cli=cfg.lark_cli,
                identity=os.environ.get("HEARTBEAT_LOG_FEISHU_AS", "bot"),
                limit=int(os.environ.get("HEARTBEAT_LOG_SYNC_LIMIT", "500")),
            )
        except Exception as exc:
            result["feishu_sync"] = {"status": "failed", "error": str(exc)}
    print(json.dumps(result, ensure_ascii=False, sort_keys=True))
    return 1 if result.get("errors") else 0


if __name__ == "__main__":
    sys.exit(main())
